<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/windowBackground">

    <!-- Uhrzeit über dem Mond -->
    <TextView
            android:id="@+id/text_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="42sp"
            android:textColor="?attr/colorOnBackground"
            android:alpha="0.5"
            android:letterSpacing="0.15"
            android:fontFamily="serif"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="36dp"/>

    <!-- Mond-Image — tappable -->
    <ImageView
            android:id="@+id/image_phase"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            app:srcCompat="@drawable/phase_100"
            app:layout_constraintTop_toBottomOf="@id/text_clock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

    <!-- Mondphasen-Name -->
    <TextView
            android:id="@+id/text_phase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textColor="?attr/colorOnBackground"
            android:letterSpacing="0.1"
            android:fontFamily="serif"
            app:layout_constraintTop_toBottomOf="@id/image_phase"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

    <!-- Divider -->
    <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="?attr/colorOnBackground"
            android:alpha="0.15"
            app:layout_constraintBottom_toTopOf="@id/bottom_strip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"/>

    <!-- Bottom info strip -->
    <LinearLayout
            android:id="@+id/bottom_strip"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/label_moon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☽"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnBackground"
                    android:alpha="0.4"/>
            <TextView
                    android:id="@+id/text_moon_sign"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textSize="13sp"
                    android:fontFamily="serif"
                    android:textColor="?attr/colorOnBackground"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/label_sun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnBackground"
                    android:alpha="0.4"/>
            <TextView
                    android:id="@+id/text_sun_sign"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textSize="13sp"
                    android:fontFamily="serif"
                    android:textColor="?attr/colorOnBackground"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/label_kin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnBackground"
                    android:alpha="0.4"/>
            <TextView
                    android:id="@+id/text_kin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="—"
                    android:textSize="13sp"
                    android:fontFamily="serif"
                    android:textColor="?attr/colorOnBackground"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Moon Detail Overlay — standardmäßig GONE, bei Tap sichtbar -->
    <LinearLayout
            android:id="@+id/moon_overlay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#EE121212"
            android:paddingHorizontal="24dp"
            android:paddingVertical="20dp"
            android:elevation="8dp"
            app:layout_constraintTop_toTopOf="@id/image_phase"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <!-- Overlay-Titel -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_title"
                android:textSize="17sp"
                android:textColor="#EFEFEF"
                android:letterSpacing="0.1"
                android:fontFamily="serif"
                android:layout_marginBottom="16dp"/>

        <!-- Beleuchtung -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_illumination_label"
                android:textSize="11sp"
                android:textColor="#666666"
                android:letterSpacing="0.08"/>
        <TextView
                android:id="@+id/overlay_illumination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="12dp"/>

        <!-- Letzter Neumond -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_last_new_label"
                android:textSize="11sp"
                android:textColor="#666666"
                android:letterSpacing="0.08"/>
        <TextView
                android:id="@+id/overlay_last_new"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="12dp"/>

        <!-- Nächster Vollmond -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_next_full_label"
                android:textSize="11sp"
                android:textColor="#666666"
                android:letterSpacing="0.08"/>
        <TextView
                android:id="@+id/overlay_next_full"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="12dp"/>

        <!-- Erstes Viertel -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_next_first_quarter_label"
                android:textSize="11sp"
                android:textColor="#666666"
                android:letterSpacing="0.08"/>
        <TextView
                android:id="@+id/overlay_next_first_quarter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="12dp"/>

        <!-- Nächster Neumond -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/moon_overlay_next_new_label"
                android:textSize="11sp"
                android:textColor="#666666"
                android:letterSpacing="0.08"/>
        <TextView
                android:id="@+id/overlay_next_new"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="16dp"/>

        <!-- Schließen -->
        <TextView
                android:id="@+id/overlay_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="@string/moon_overlay_close"
                android:textSize="13sp"
                android:textColor="#555555"
                android:letterSpacing="0.05"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
