<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Cartomancer" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Nav Drawer aktiver Item Highlight -->
        <item name="colorControlHighlight">#22000000</item>
        <item name="navigationViewStyle">@style/Widget.Design.NavigationView</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/darkGray</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/darkGray</item>
        <item name="colorSecondaryVariant">@color/darkGray</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="backgroundColor">@color/white</item>
    </style>

    <style name="Theme.Cartomancer.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="CartomancerDatePicker" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/darkGray</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/lightGray</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
    </style>
</resources>